{
  "id": "com.oasystem",
  "name": "OA Office System",
  "version": "1.0.0",
  "permissions": [
    "storage",
    "auth",
    "database"
  ],
  "entry": "index.js",
  "routes": [
    {
      "path": "/dashboard",
      "component": "Dashboard.vue"
    },
    {
      "path": "/tasks",
      "component": "TaskList.vue"
    },
    {
      "path": "/projects",
      "component": "ProjectList.vue"
    }
  ]
} 